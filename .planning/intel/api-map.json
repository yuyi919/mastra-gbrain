    "script:import": {
      "kind": "cli-script",
      "file": "src/scripts/import.ts",
      "export": "bulkImport",
      "cli": "bun run src/scripts/import.ts [directory] [--workers N] [--fresh]",
      "invocation": "manual cli",
      "description": "Directory-level markdown ingestion utility with checkpoint resume."
    },
    "script:embed": {
      "kind": "cli-script",
      "file": "src/scripts/embed.ts",
