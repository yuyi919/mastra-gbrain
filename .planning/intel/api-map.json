{
  "_meta": {
    "updated_at": "2026-04-24T06:35:26.800Z",
    "version": 1
  },
  "entries": {
    "agent:gbrain": {
      "kind": "agent",
      "id": "gbrain",
      "file": "src/agent/index.ts",
      "factory": "createGBrainAgent",
      "registers_tools": [
        "search",
        "ingest",
        "bulk-import",
        "list-pages",
        "read-page",
        "delete-page",
        "get-page-info",
        "add-tag",
        "remove-tag",
        "get-links",
        "add-link",
        "remove-link",
        "get-timeline",
        "get-config",
        "set-config",
        "get-raw-data",
        "put-raw-data"
      ],
      "invocation": "runtime",
      "description": "Mastra Agent that exposes the knowledge-base tool surface."
    },
    "workflow:gbrain-ingest": {
      "kind": "workflow",
      "id": "gbrain-ingest",
      "file": "src/ingest/workflow.ts",
      "factory": "createIngestionWorkflow",
      "steps": [
        "parse",
        "chunk",
        "embed",
        "persist"
      ],
      "input": [
        "slug?",
        "relativePath?",
        "content",
        "noEmbed?"
      ],
      "output": [
        "slug",
        "status",
        "chunks",
        "error?"
      ],
      "invocation": "createIngestTool.execute / createBulkImportTool.execute"
    },
    "tool:search": {
      "kind": "mastra-tool",
      "id": "search",
      "file": "src/tools/search.ts",
      "factory": "createSearchTool",
      "input": [
        "query",
        "limit?"
      ],
      "output": [
        "query",
        "results"
      ],
      "invocation": "agent tool call",
      "description": "Hybrid keyword + vector retrieval."
    },
    "tool:ingest": {
      "kind": "mastra-tool",
      "id": "ingest",
      "file": "src/tools/ingest.ts",
      "factory": "createIngestTool",
      "input": [
        "relativePath",
        "content"
      ],
      "output": [
        "slug",
        "status",
        "chunks",
        "error?"
      ],
      "invocation": "agent tool call",
      "description": "Ingest one markdown page through gbrain-ingest workflow."
    },
    "tool:bulk-import": {
      "kind": "mastra-tool",
      "id": "bulk-import",
      "file": "src/tools/import.ts",
      "factory": "createBulkImportTool",
      "input": [
        "directoryPath"
      ],
      "output": [
        "success",
        "message",
        "summary|error"
      ],
      "invocation": "agent tool call",
      "description": "Recursively import markdown files from local directory."
    },
    "tool:list-pages": {
      "kind": "mastra-tool",
      "id": "list-pages",
      "file": "src/tools/list.ts",
      "factory": "createListPagesTool",
      "input": [
        "type?",
        "tag?",
        "tags?",
        "limit?",
        "offset?",
        "updated_after?"
      ],
      "output": [
        "count",
        "pages"
      ],
      "invocation": "agent tool call"
    },
