{
  "model_profile": "quality",
  "workflow": {
    "auto": false,
    "auto_advance": true,
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "research_before_questions": true,
    "discuss_mode": "assumptions",
    "plan_chunked": true,
    "skip_discuss": false,
    "use_worktrees": true
  },
  "hooks": {
    "context_warnings": true
  },
  "features": {
    "thinking_partner": true,
    "global_learnings": true
  },
  "learnings": {
    "max_inject": 12
  },
  "graphify": {
    "enabled": true,
    "build_timeout": 300
  },
  "preferences": {
    "testing": "bun test",
    "linting": "tsc --noEmit && biome check",
    "strict_mode": true
  },
  "response_language": "zh"
}
