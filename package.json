{
  "name": "mastra-gbrain",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "test": "pnpm clean && bun test",
    "clean": "rimraf ./tmp/*.db -g",
    "check": "biome check .",
    "check:fix": "node scripts/check-fix.mjs",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "build": "tsup",
    "dev": "tsup --watch",
    "build:dts": "tsc --build tsconfig.type.json"
  },
  "dependencies": {
    "@mastra/core": "catalog:",
    "@mastra/libsql": "catalog:",
    "@standard-schema/spec": "^1.1.0",
    "@types/unist": "^3.0.3",
    "@yuyi919/tslibs-effect": "catalog:",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unist-util-visit": "^5.1.0",
    "unist-util-visit-parents": "^6.0.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@effect/platform-bun": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@types/bun": "catalog:",
    "@typia/unplugin": "^12.0.1",
    "drizzle-kit": "^0.31.10",
    "effect": "4.0.0-beta.55",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "node-llama-cpp": "^3.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "typia": "^12.0.1"
  },
  "lint-staged": {
    "*.{ts,mjs,json}": "pnpm check:fix --"
  },
  "resolutions": {
    "es-toolkit": "1.46.0"
  },
  "pnpm": {
    "overrides": {
      "es-toolkit": "1.46.0"
    }
  }
}
