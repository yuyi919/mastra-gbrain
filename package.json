{
  "name": "mastra-gbrain",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "test": "bun test && pnpm clean",
    "clean": "rimraf ./tmp/*.db -g",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "build": "tsup",
    "dev": "tsup --watch",
    "build:dts": "tsc --build tsconfig.type.json"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@mastra/core": "^1.24.1",
    "@mastra/libsql": "^1.8.0",
    "@types/unist": "^3.0.3",
    "@yuyi919/tslibs-effect": "catalog:",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unist-util-visit": "^5.1.0",
    "unist-util-visit-parents": "^6.0.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typia/unplugin": "^12.0.1",
    "bun-types": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "node-llama-cpp": "^3.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "typia": "^12.0.1"
  }
}
